{
  "includePatterns": ["**/*.tsx"],
  "translationFiles": {
    "filePattern": "locales/**/*.json"
  },
  "keySeparator": ".",
  "namespaceSeparator": ":",
  "defaultNamespace": "translation",
  "primaryLanguages": ["en", "ja"],
  "frameworks": {
    "i18next": {
      "preferSelector": true
    }
  }
}
