{
    "mcpServers": {
        "deepwiki": {
            "command": "bunx",
            "args": [
                "mcp-remote",
                "https://mcp.deepwiki.com/sse"
            ]
        },
        "Context7": {
            "command": "bunx",
            "args": [
                "-y",
                "@upstash/context7-mcp@latest"
            ]
        },
        "time": {
            "command": "uvx",
            "args": [
                "mcp-server-time",
                "--local-timezone",
                "Asia/Tokyo"
            ]
        }
    }
}
